---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business, services, faqs } from '../site';

const title = `${business.name} | Clothing Alterations in Doylestown & Bucks County, PA`;
const description =
  'Affordable, expert clothing alterations in Doylestown & Bucks County, PA. Hemming, sleeve adjustments, taking in & letting out, plus zipper and button repairs. Text for a fast, free quote.';

const smsLink = `sms:${business.phoneLink}`;

// Friendly grammatical list of the main towns for the intro copy.
const topTowns = business.areaServed.slice(0, 4).join(', ');
---

<BaseLayout title={title} description={description}>
  <header class="site-header">
    <div class="container">
      <a class="brand" href="#top">Doylestown <span>Alterations</span></a>
      <nav class="nav" aria-label="Primary">
        <div class="nav-links">
          <a href="#services">Services</a>
          <a href="#pricing">Pricing</a>
          <a href="#about">About</a>
          <a href="#area">Service Area</a>
          <a href="#faq">FAQ</a>
        </div>
        <a class="btn btn-primary" href={smsLink}>Text for a quote</a>
      </nav>
    </div>
  </header>

  <main id="top">
    <!-- HERO -->
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Doylestown &amp; Bucks County, PA</p>
          <h1>Clothing alterations that fit your life — and your budget.</h1>
          <p class="lead">
            Friendly, professional alterations from an experienced seamstress
            serving the Doylestown area. From hems to sleeves to quick repairs,
            your favorite clothes will fit like they were made for you.
          </p>
          <div class="btn-row" style="margin-top:1.6rem">
            <a class="btn btn-primary" href={smsLink}>📱 Text {business.phoneDisplay}</a>
            <a class="btn btn-secondary" href="#services">See services</a>
          </div>
          <p style="margin-top:1rem;color:var(--ink-soft);font-size:0.95rem">
            <strong>Text is the best way to reach us.</strong> Send a photo and a
            quick note about what you need for a fast, free quote.
          </p>
        </div>

        <aside class="hero-card">
          <h3>Why neighbors choose us</h3>
          <ul class="checklist">
            <li>Experienced, trained in clothing alterations</li>
            <li>Honest, competitive pricing</li>
            <li>Quick turnaround — most jobs in a few days</li>
            <li>Personal, one-on-one service</li>
            <li>Convenient local drop-off &amp; pick-up</li>
          </ul>
        </aside>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">What we do</p>
          <h2>Everyday alterations &amp; repairs</h2>
          <p class="lead">
            We focus on the alterations people need most — done well, and done
            affordably. (We don’t make new garments from scratch.)
          </p>
        </div>
        <div class="cards">
          {
            services.map((s) => (
              <article class="card">
                <h3>{s.title}</h3>
                <p>{s.description}</p>
                <span class="price">
                  from {s.fromPrice} <small>· final price by quote</small>
                </span>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- PRICING -->
    <section id="pricing" class="section-cream-deep">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Simple, fair pricing</p>
          <h2>Starting prices</h2>
          <p class="lead">
            Every garment is a little different, so the prices below are starting
            points. Text a photo and a quick description for an exact, no-pressure
            quote.
          </p>
        </div>
        <div class="cards">
          {
            services.map((s) => (
              <article class="card">
                <h3>{s.title}</h3>
                <span class="price" style="font-size:1.4rem">
                  from {s.fromPrice}
                </span>
              </article>
            ))
          }
        </div>
        <p class="pricing-note">
          Prices vary by garment, fabric, and the work involved. You’ll always
          get a clear quote before any work begins.
        </p>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about">
      <div class="container about-grid">
        <div>
          <p class="eyebrow">About</p>
          <h2>An experienced seamstress, right in your neighborhood</h2>
          <p>
            Doylestown Alterations is a home-based alterations service in
            {business.locality}, Bucks County. After years of experience and a
            long history of happy customers, our seamstress is now offering that
            same careful, trained craftsmanship to neighbors across the
            Doylestown area.
          </p>
          <p>
            Every garment gets personal attention and an honest price. Whether
            it’s hemming a new pair of pants, taking in a dress for a special
            occasion, or fixing a stubborn zipper, you can count on quality work
            and a friendly, neighborly experience.
          </p>
          <div class="stat-row">
            <div class="stat">
              <div class="num">Years</div>
              <div class="label">of alterations experience</div>
            </div>
            <div class="stat">
              <div class="num">Local</div>
              <div class="label">serving the Doylestown area</div>
            </div>
            <div class="stat">
              <div class="num">Fair</div>
              <div class="label">competitive pricing</div>
            </div>
          </div>
        </div>
        <aside class="hero-card">
          <h3>Ready when you are</h3>
          <p style="color:var(--ink-soft)">
            The easiest way to get started is a quick text. Tell us what you
            need, attach a photo if you can, and we’ll reply with a price and a
            time to drop off your garments.
          </p>
          <div class="btn-row" style="margin-top:1rem">
            <a class="btn btn-primary" href={smsLink}>Text us</a>
          </div>
        </aside>
      </div>
    </section>

    <!-- SERVICE AREA -->
    <section id="area" class="section-cream-deep">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Where we serve</p>
          <h2>Proudly serving the Doylestown &amp; Bucks County area</h2>
          <p class="lead">
            Based near {business.locality} and serving {topTowns}, and the
            surrounding communities.
          </p>
        </div>
        <div class="pill-row">
          {business.areaServed.map((town) => <span class="pill">{town}</span>)}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">Good to know</p>
          <h2>Frequently asked questions</h2>
        </div>
        <div class="faq-list">
          {
            faqs.map((f) => (
              <details class="faq">
                <summary>{f.q}</summary>
                <p>{f.a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>

    <!-- CTA / CONTACT -->
    <section id="contact" class="cta">
      <div class="container">
        <p class="eyebrow" style="color:rgba(255,255,255,0.85)">Get a free quote</p>
        <h2>Let’s get your clothes fitting perfectly.</h2>
        <p class="lead">
          Text a photo and a short description of what you need — you’ll get a
          friendly, no-obligation quote, usually the same day.
        </p>
        <div class="btn-row">
          <a class="btn btn-primary" href={smsLink}>📱 Text {business.phoneDisplay}</a>
        </div>
        <p style="margin-top:1rem;color:rgba(255,255,255,0.85);font-size:0.95rem">
          Please text rather than call — it’s the fastest way to reach us.
        </p>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div>
        <strong>{business.name}</strong><br />
        <span class="muted">
          Serving Doylestown &amp; Bucks County, {business.region}
        </span>
      </div>
      <div>
        <a href={smsLink}>Text {business.phoneDisplay}</a><br />
        <span class="muted">By appointment · Local drop-off &amp; pick-up</span>
      </div>
    </div>
  </footer>
</BaseLayout>
